import React, { useState, useRef, useEffect } from 'react';
import { Send, Plus, Minus, User, Menu, ChevronLeft, ChevronRight, MessageSquare, Settings, Key, CreditCard, LogOut, Trash2, Edit2, X, Zap, BarChart3, Clock } from 'lucide-react';

const LLMComparisonTool = () => {
  const [viewMode, setViewMode] = useState('grid');
  const [panels, setPanels] = useState([
    { id: 1, model: '', response: '', loading: false, error: null }
  ]);
  const [userMessage, setUserMessage] = useState('');
  const [showModelDropdown, setShowModelDropdown] = useState(null);
  const [carouselIndex, setCarouselIndex] = useState(0);
  const [sidebarOpen, setSidebarOpen] = useState(false);
  const [sidebarTab, setSidebarTab] = useState('chats');
  const [apiKeys, setApiKeys] = useState({
    openai: '',
    gemini: '',
    anthropic: '',
    copilot: ''
  });
  const [editingKey, setEditingKey] = useState(null);
  const [chats, setChats] = useState([
    { id: 1, title: 'Product comparison query', date: '2024-01-20', preview: 'Compare the features of...' },
    { id: 2, title: 'Code review assistance', date: '2024-01-19', preview: 'Review this Python code...' },
    { id: 3, title: 'Marketing copy ideas', date: '2024-01-18', preview: 'Generate marketing copy...' },
    { id: 4, title: 'Technical documentation', date: '2024-01-17', preview: 'Help me write technical...' },
  ]);
  const [currentChatId, setCurrentChatId] = useState(null);

  const availableModels = [
    { id: 'openai', name: 'OpenAI GPT-4', models: ['gpt-4', 'gpt-3.5-turbo'], icon: '🤖' },
    { id: 'gemini', name: 'Google Gemini Pro', models: ['gemini-pro'], icon: '✨' },
    { id: 'anthropic', name: 'Claude Sonnet', models: ['claude-sonnet-4-5'], icon: '🔷' },
    { id: 'copilot', name: 'Microsoft Copilot', models: ['copilot-gpt4'], icon: '💼' }
  ];

  const addPanel = () => {
    if (panels.length < 4) {
      setPanels([...panels, { 
        id: Date.now(), 
        model: '', 
        response: '', 
        loading: false,
        error: null 
      }]);
    }
  };

  const removePanel = () => {
    if (panels.length > 1) {
      setPanels(panels.slice(0, -1));
    }
  };

  const toggleModel = (panelId, modelInfo) => {
    setPanels(panels.map(panel => 
      panel.id === panelId 
        ? { ...panel, model: panel.model === modelInfo ? '' : modelInfo }
        : panel
    ));
    setShowModelDropdown(null);
  };

  const callLLMApi = async (model, message) => {
    await new Promise(resolve => setTimeout(resolve, 2000));
    
    const responses = {
      'openai-gpt-4': `# OpenAI GPT-4 Analysis\n\n${message}\n\nThis is a simulated response from GPT-4. The model demonstrates strong reasoning capabilities and comprehensive understanding of complex queries. In production, this would connect to the actual OpenAI API with your configured API key.`,
      'openai-gpt-3.5-turbo': `# OpenAI GPT-3.5 Turbo Response\n\n${message}\n\nGPT-3.5 Turbo provides fast, efficient responses. This simulated output demonstrates the model's quick processing capabilities.`,
      'gemini-gemini-pro': `# Google Gemini Pro Response\n\n${message}\n\nGemini Pro offers multimodal capabilities and strong analytical performance. This simulated response showcases the model's comprehensive approach to problem-solving.`,
      'anthropic-claude-sonnet-4-5': `# Claude Sonnet 4.5 Response\n\n${message}\n\nClaude excels at nuanced understanding and detailed analysis. This simulated response demonstrates the model's careful reasoning and thorough explanations.`,
      'copilot-copilot-gpt4': `# Microsoft Copilot Response\n\n${message}\n\nMicrosoft Copilot integrates seamlessly with productivity tools. This simulated response shows the model's practical, solution-oriented approach.`
    };

    return responses[model] || 'Response from ' + model;
  };

  const handleSend = async () => {
    if (!userMessage.trim()) return;

    const activePanels = panels.filter(p => p.model);
    if (activePanels.length === 0) {
      alert('Please select at least one model');
      return;
    }

    setPanels(panels.map(panel => 
      panel.model ? { ...panel, loading: true, error: null, response: '' } : panel
    ));

    for (const panel of panels) {
      if (panel.model) {
        try {
          const response = await callLLMApi(panel.model, userMessage);
          setPanels(prev => prev.map(p => 
            p.id === panel.id 
              ? { ...p, response, loading: false }
              : p
          ));
        } catch (error) {
          setPanels(prev => prev.map(p => 
            p.id === panel.id 
              ? { ...p, error: 'Failed to get response', loading: false }
              : p
          ));
        }
      }
    }
  };

  const getGridClass = () => {
    switch(panels.length) {
      case 1: return 'grid-cols-1';
      case 2: return 'grid-cols-2';
      case 3: return 'grid-cols-3';
      case 4: return 'grid-cols-2';
      default: return 'grid-cols-1';
    }
  };

  const deleteChat = (chatId) => {
    setChats(chats.filter(chat => chat.id !== chatId));
    if (currentChatId === chatId) {
      setCurrentChatId(null);
    }
  };

  const loadChat = (chatId) => {
    setCurrentChatId(chatId);
    setSidebarOpen(false);
  };

  const saveApiKey = (provider) => {
    setEditingKey(null);
  };

  const ModelSelector = ({ panel }) => {
    const selectedModel = availableModels.find(m => m.models.some(model => `${m.id}-${model}` === panel.model));
    
    return (
      <div className="relative">
        <button
          onClick={() => setShowModelDropdown(showModelDropdown === panel.id ? null : panel.id)}
          className="flex items-center gap-3 px-4 py-2.5 bg-amber-900/60 backdrop-blur-sm text-amber-100 rounded-lg text-sm font-semibold hover:bg-amber-900/80 transition-all shadow-lg border border-amber-600/30 group"
        >
          {panel.model ? (
            <>
              <span className="text-lg">{selectedModel?.icon}</span>
              <span>{selectedModel?.name}</span>
            </>
          ) : (
            <>
              <span className="text-amber-300">Select Model</span>
            </>
          )}
          <ChevronLeft className={`w-4 h-4 ml-auto transition-transform ${showModelDropdown === panel.id ? '-rotate-90' : 'rotate-180'}`} />
        </button>

        {showModelDropdown === panel.id && (
          <div className="absolute top-full mt-2 left-0 bg-gray-800 rounded-xl shadow-2xl p-2 min-w-[280px] z-50 border border-gray-700">
            <div className="p-2 border-b border-gray-700 mb-2">
              <p className="text-xs font-semibold text-gray-400 uppercase tracking-wide">Available Models</p>
            </div>
            {availableModels.map(provider => (
              <div key={provider.id}>
                {provider.models.map(model => {
                  const modelId = `${provider.id}-${model}`;
                  const isSelected = panel.model === modelId;
                  return (
                    <button
                      key={model}
                      onClick={() => toggleModel(panel.id, modelId)}
                      className={`flex items-center gap-3 w-full px-3 py-2.5 rounded-lg text-left transition-all ${
                        isSelected ? 'bg-blue-600 text-white' : 'hover:bg-gray-700 text-gray-300'
                      }`}
                    >
                      <span className="text-xl">{provider.icon}</span>
                      <div className="flex-1">
                        <div className="font-semibold text-sm">{provider.name}</div>
                      </div>
                      <div className={`w-5 h-5 rounded-full border-2 flex items-center justify-center transition-all ${
                        isSelected ? 'bg-white border-white' : 'border-gray-500'
                      }`}>
                        {isSelected && (
                          <svg className="w-3 h-3 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={3} d="M5 13l4 4L19 7" />
                          </svg>
                        )}
                      </div>
                    </button>
                  );
                })}
              </div>
            ))}
          </div>
        )}
      </div>
    );
  };

  const Panel = ({ panel, isCarousel = false }) => (
    <div className={`bg-gradient-to-br from-amber-700 via-yellow-600 to-amber-800 rounded-xl p-6 flex flex-col shadow-xl border border-amber-600/30 ${
      isCarousel ? 'h-full' : 'min-h-[500px]'
    }`}>
      <ModelSelector panel={panel} />
      
      <div className="flex-1 mt-5 overflow-y-auto">
        {panel.loading ? (
          <div className="flex flex-col items-center justify-center h-full">
            <div className="relative">
              <div className="w-12 h-12 border-4 border-amber-300/30 border-t-amber-200 rounded-full animate-spin"></div>
            </div>
            <p className="mt-4 text-amber-50 font-medium">Generating response...</p>
            <p className="text-xs text-amber-200 mt-1">Please wait</p>
          </div>
        ) : panel.response ? (
          <div className="prose prose-sm max-w-none">
            <div className="bg-gradient-to-br from-amber-900/40 to-yellow-900/40 backdrop-blur-sm rounded-lg p-5 shadow-lg border border-amber-500/20">
              <div className="text-amber-50 whitespace-pre-wrap leading-relaxed font-['Inter','system-ui',sans-serif]">
                {panel.response}
              </div>
            </div>
          </div>
        ) : (
          <div className="flex items-center justify-center h-full">
            <div className="text-center max-w-xs">
              <div className="w-16 h-16 mx-auto mb-4 bg-amber-800/40 backdrop-blur-sm rounded-2xl flex items-center justify-center border border-amber-600/30">
                <MessageSquare className="w-8 h-8 text-amber-300" />
              </div>
              <h3 className="text-amber-100 font-semibold mb-2">
                {panel.model ? 'Ready to assist' : 'Select a model'}
              </h3>
              <p className="text-amber-200 text-sm">
                {panel.model ? 'Type your message below to get started' : 'Choose an AI model from the dropdown above'}
              </p>
            </div>
          </div>
        )}
      </div>
    </div>
  );

  const Sidebar = () => (
    <>
      {sidebarOpen && (
        <div 
          className="fixed inset-0 bg-black/30 backdrop-blur-sm z-40 transition-opacity"
          onClick={() => setSidebarOpen(false)}
        />
      )}
      
      <div className={`fixed top-0 left-0 h-full w-72 bg-gray-900 shadow-2xl z-50 transform transition-transform duration-300 ${
        sidebarOpen ? 'translate-x-0' : '-translate-x-full'
      }`}>
        <div className="absolute top-5 right-5 z-10">
          <button 
            onClick={() => setSidebarOpen(false)}
            className="p-2 hover:bg-gray-800 rounded-lg transition-colors"
          >
            <X className="w-5 h-5 text-gray-400" />
          </button>
        </div>

        <div className="p-6 border-b border-gray-800">
          <h2 className="text-white font-bold text-xl">LLM Compare</h2>
          <p className="text-gray-500 text-xs mt-1">AI Model Comparison Tool</p>
        </div>

        <div className="px-4 py-3 space-y-1">
          <button
            onClick={() => setSidebarTab('chats')}
            className={`w-full flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-all ${
              sidebarTab === 'chats' 
                ? 'bg-gray-800 text-white shadow-lg' 
                : 'text-gray-400 hover:bg-gray-800/50 hover:text-white'
            }`}
          >
            <MessageSquare className="w-5 h-5" />
            Chat History
          </button>
          <button
            onClick={() => setSidebarTab('account')}
            className={`w-full flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-all ${
              sidebarTab === 'account' 
                ? 'bg-gray-800 text-white shadow-lg' 
                : 'text-gray-400 hover:bg-gray-800/50 hover:text-white'
            }`}
          >
            <User className="w-5 h-5" />
            Account
          </button>
          <button
            onClick={() => setSidebarTab('settings')}
            className={`w-full flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-all ${
              sidebarTab === 'settings' 
                ? 'bg-gray-800 text-white shadow-lg' 
                : 'text-gray-400 hover:bg-gray-800/50 hover:text-white'
            }`}
          >
            <Settings className="w-5 h-5" />
            Settings
          </button>
        </div>

        <div className="flex-1 overflow-y-auto px-4 py-4">
          {sidebarTab === 'chats' && (
            <div className="space-y-2">
              <button
                onClick={() => {
                  setCurrentChatId(null);
                  setPanels([{ id: 1, model: '', response: '', loading: false, error: null }]);
                  setSidebarOpen(false);
                }}
                className="w-full px-4 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-medium transition-all text-sm shadow-lg hover:shadow-xl"
              >
                <Plus className="w-4 h-4 inline mr-2" />
                New Comparison
              </button>
              
              {chats.map(chat => (
                <div
                  key={chat.id}
                  className={`group p-3 rounded-lg cursor-pointer transition-all ${
                    currentChatId === chat.id 
                      ? 'bg-gray-800 shadow-lg' 
                      : 'hover:bg-gray-800/50'
                  }`}
                >
                  <div 
                    onClick={() => loadChat(chat.id)}
                    className="flex-1"
                  >
                    <div className="flex items-start justify-between">
                      <h3 className="text-white font-medium text-sm line-clamp-1">{chat.title}</h3>
                      <button
                        onClick={(e) => {
                          e.stopPropagation();
                          deleteChat(chat.id);
                        }}
                        className="opacity-0 group-hover:opacity-100 p-1 hover:bg-gray-700 rounded transition-all"
                      >
                        <Trash2 className="w-3.5 h-3.5 text-red-400" />
                      </button>
                    </div>
                    <p className="text-gray-500 text-xs mt-1 line-clamp-1">{chat.preview}</p>
                    <div className="flex items-center gap-1 mt-2">
                      <Clock className="w-3 h-3 text-gray-600" />
                      <p className="text-gray-600 text-xs">{chat.date}</p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          )}

          {sidebarTab === 'account' && (
            <div className="space-y-5">
              <div className="p-4 bg-gradient-to-br from-gray-800 to-gray-900 rounded-xl border border-gray-800">
                <div className="flex items-center gap-4">
                  <div className="w-14 h-14 bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl flex items-center justify-center shadow-lg">
                    <User className="w-7 h-7 text-white" />
                  </div>
                  <div>
                    <h3 className="text-white font-semibold text-sm">John Doe</h3>
                    <p className="text-gray-500 text-xs">john.doe@example.com</p>
                    <span className="inline-block mt-1 px-2 py-0.5 bg-blue-500/20 text-blue-400 text-xs rounded-full font-medium">Pro Plan</span>
                  </div>
                </div>
              </div>

              <div className="space-y-2">
                <button className="w-full flex items-center gap-3 p-3 bg-gray-800 hover:bg-gray-750 rounded-lg text-white transition-all text-sm group">
                  <Edit2 className="w-4 h-4 text-gray-400 group-hover:text-white transition-colors" />
                  <span>Edit Profile</span>
                </button>
                
                <button className="w-full flex items-center gap-3 p-3 bg-gray-800 hover:bg-gray-750 rounded-lg text-white transition-all text-sm group">
                  <CreditCard className="w-4 h-4 text-gray-400 group-hover:text-white transition-colors" />
                  <span>Billing & Plans</span>
                </button>
                
                <button className="w-full flex items-center gap-3 p-3 bg-red-600/10 hover:bg-red-600/20 border border-red-600/20 rounded-lg text-red-400 transition-all text-sm">
                  <LogOut className="w-4 h-4" />
                  <span>Sign Out</span>
                </button>
              </div>

              <div className="pt-4 border-t border-gray-800">
                <div className="flex items-center justify-between mb-3">
                  <h4 className="text-gray-400 text-xs font-semibold uppercase tracking-wide">Usage This Month</h4>
                  <BarChart3 className="w-4 h-4 text-gray-600" />
                </div>
                <div className="space-y-3">
                  <div>
                    <div className="flex justify-between text-xs mb-1.5">
                      <span className="text-gray-500">API Calls</span>
                      <span className="text-white font-medium">1,247 / 5,000</span>
                    </div>
                    <div className="w-full bg-gray-800 rounded-full h-2 overflow-hidden">
                      <div className="bg-gradient-to-r from-blue-600 to-blue-500 h-2 rounded-full transition-all" style={{ width: '25%' }}></div>
                    </div>
                  </div>
                  <div>
                    <div className="flex justify-between text-xs mb-1.5">
                      <span className="text-gray-500">Tokens Used</span>
                      <span className="text-white font-medium">2.4M / 10M</span>
                    </div>
                    <div className="w-full bg-gray-800 rounded-full h-2 overflow-hidden">
                      <div className="bg-gradient-to-r from-green-600 to-green-500 h-2 rounded-full transition-all" style={{ width: '24%' }}></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          )}

          {sidebarTab === 'settings' && (
            <div className="space-y-6">
              <div>
                <div className="flex items-center gap-2 mb-3">
                  <Key className="w-4 h-4 text-gray-400" />
                  <h3 className="text-white font-semibold text-sm">API Configuration</h3>
                </div>
                <div className="space-y-2">
                  {availableModels.map(provider => (
                    <div key={provider.id} className="p-3 bg-gray-800 rounded-lg border border-gray-700">
                      <div className="flex items-center justify-between mb-2">
                        <div className="flex items-center gap-2">
                          <span className="text-base">{provider.icon}</span>
                          <span className="text-white text-xs font-medium">{provider.name}</span>
                        </div>
                        <button
                          onClick={() => setEditingKey(editingKey === provider.id ? null : provider.id)}
                          className="text-blue-500 hover:text-blue-400 text-xs font-medium transition-colors"
                        >
                          {editingKey === provider.id ? 'Save' : 'Configure'}
                        </button>
                      </div>
                      {editingKey === provider.id ? (
                        <input
                          type="password"
                          value={apiKeys[provider.id]}
                          onChange={(e) => setApiKeys({ ...apiKeys, [provider.id]: e.target.value })}
                          placeholder="sk-..."
                          className="w-full px-3 py-2 bg-gray-900 text-white text-xs rounded border border-gray-700 focus:border-blue-500 outline-none transition-colors"
                        />
                      ) : (
                        <div className="flex items-center gap-2">
                          <div className={`w-2 h-2 rounded-full ${apiKeys[provider.id] ? 'bg-green-500' : 'bg-gray-600'}`}></div>
                          <span className="text-gray-500 text-xs">
                            {apiKeys[provider.id] ? 'Configured' : 'Not configured'}
                          </span>
                        </div>
                      )}
                    </div>
                  ))}
                </div>
              </div>

              <div>
                <h3 className="text-white font-semibold mb-3 text-sm">Preferences</h3>
                <div className="space-y-2">
                  <label className="flex items-center justify-between p-3 bg-gray-800 rounded-lg cursor-pointer hover:bg-gray-750 transition-colors border border-gray-700">
                    <span className="text-white text-xs">Dark Mode</span>
                    <div className="relative">
                      <input type="checkbox" defaultChecked className="sr-only peer" />
                      <div className="w-11 h-6 bg-gray-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
                    </div>
                  </label>
                  
                  <label className="flex items-center justify-between p-3 bg-gray-800 rounded-lg cursor-pointer hover:bg-gray-750 transition-colors border border-gray-700">
                    <span className="text-white text-xs">Auto-save Conversations</span>
                    <div className="relative">
                      <input type="checkbox" defaultChecked className="sr-only peer" />
                      <div className="w-11 h-6 bg-gray-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
                    </div>
                  </label>
                  
                  <label className="flex items-center justify-between p-3 bg-gray-800 rounded-lg cursor-pointer hover:bg-gray-750 transition-colors border border-gray-700">
                    <span className="text-white text-xs">Show Response Time</span>
                    <div className="relative">
                      <input type="checkbox" className="sr-only peer" />
                      <div className="w-11 h-6 bg-gray-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
                    </div>
                  </label>
                </div>
              </div>

              <div>
                <h3 className="text-white font-semibold mb-3 text-sm">Data Management</h3>
                <button className="w-full p-3 bg-gray-800 hover:bg-gray-750 border border-gray-700 rounded-lg text-white text-xs transition-all flex items-center justify-center gap-2">
                  <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                  </svg>
                  Export Chat History
                </button>
              </div>
            </div>
          )}
        </div>
      </div>
    </>
  );

  return (
    <div className="h-screen bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 flex overflow-hidden">
      <Sidebar />
      
      <div className="flex-1 flex flex-col">
        <div className="bg-gray-900 border-b border-gray-800 px-6 py-4 flex items-center justify-between shadow-xl">
          <div className="flex items-center gap-4">
            <button 
              onClick={() => setSidebarOpen(true)}
              className="p-2 hover:bg-gray-800 rounded-lg transition-colors"
            >
              <Menu className="w-5 h-5 text-gray-400" />
            </button>
            <div>
              <h1 className="text-white font-bold text-lg">AI Model Comparison</h1>
              <p className="text-gray-500 text-xs">Compare responses across different LLMs</p>
            </div>
          </div>
          <button 
            onClick={() => {
              setSidebarOpen(true);
              setSidebarTab('account');
            }}
            className="flex items-center gap-3 px-4 py-2 hover:bg-gray-800 rounded-lg transition-colors"
          >
            <div className="text-right">
              <div className="text-sm font-semibold text-white">John Doe</div>
              <div className="text-xs text-gray-400">Pro Account</div>
            </div>
            <div className="w-9 h-9 bg-gradient-to-br from-blue-500 to-blue-600 rounded-lg flex items-center justify-center shadow-sm">
              <User className="w-5 h-5 text-white" />
            </div>
          </button>
        </div>

        <div className="flex-1 overflow-auto p-6 bg-gradient-to-br from-gray-900 to-gray-800">
          {viewMode === 'carousel' ? (
            <div className="relative h-full flex flex-col">
              <div className="flex-1">
                <Panel panel={panels[carouselIndex]} isCarousel={true} />
              </div>
              
              <div className="flex items-center justify-center gap-4 mt-6 pb-4">
                <button
                  onClick={() => setCarouselIndex(Math.max(0, carouselIndex - 1))}
                  disabled={carouselIndex === 0}
                  className="p-3 rounded-lg bg-gray-800 border border-gray-700 text-gray-300 disabled:opacity-30 hover:bg-gray-700 transition-all shadow-sm disabled:cursor-not-allowed"
                >
                  <ChevronLeft className="w-5 h-5" />
                </button>
                
                <div className="flex gap-2">
                  {panels.map((_, idx) => (
                    <button
                      key={idx}
                      onClick={() => setCarouselIndex(idx)}
                      className={`h-2 rounded-full transition-all ${
                        idx === carouselIndex ? 'bg-amber-500 w-8' : 'bg-gray-700 w-2 hover:bg-gray-600'
                      }`}
                    />
                  ))}
                </div>
                
                <button
                  onClick={() => setCarouselIndex(Math.min(panels.length - 1, carouselIndex + 1))}
                  disabled={carouselIndex === panels.length - 1}
                  className="p-3 rounded-lg bg-gray-800 border border-gray-700 text-gray-300 disabled:opacity-30 hover:bg-gray-700 transition-all shadow-sm disabled:cursor-not-allowed"
                >
                  <ChevronRight className="w-5 h-5" />
                </button>
              </div>
            </div>
          ) : (
            <div className={`grid ${getGridClass()} gap-5 h-full auto-rows-fr`}>
              {panels.map(panel => (
                <Panel key={panel.id} panel={panel} />
              ))}
            </div>
          )}
        </div>

        <div className="bg-gray-900 border-t border-gray-800 px-6 py-4 shadow-2xl">
          <div className="flex items-center gap-4 max-w-7xl mx-auto">
            <div className="flex gap-2">
              <button
                onClick={removePanel}
                disabled={panels.length <= 1}
                className="p-3 bg-gray-800 hover:bg-gray-700 rounded-lg disabled:opacity-30 disabled:cursor-not-allowed transition-all border border-gray-700"
                title="Remove panel"
              >
                <Minus className="w-5 h-5 text-gray-300" />
              </button>

              <button
                onClick={addPanel}
                disabled={panels.length >= 4}
                className="p-3 bg-gray-800 hover:bg-gray-700 rounded-lg disabled:opacity-30 disabled:cursor-not-allowed transition-all border border-gray-700"
                title="Add panel"
              >
                <Plus className="w-5 h-5 text-gray-300" />
              </button>
            </div>

            <div className="flex-1 flex items-center gap-3 bg-gray-800 rounded-xl px-5 py-3 border border-gray-700 focus-within:border-amber-500 focus-within:ring-2 focus-within:ring-amber-500/20 transition-all">
              <input
                type="text"
                value={userMessage}
                onChange={(e) => setUserMessage(e.target.value)}
                onKeyPress={(e) => e.key === 'Enter' && handleSend()}
                placeholder="Type your message to compare across models..."
                className="flex-1 bg-transparent text-white placeholder-gray-500 outline-none text-sm"
              />
              <button className="p-2 hover:bg-gray-700 rounded-lg transition-colors">
                <svg className="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" />
                </svg>
              </button>
              <button 
                onClick={handleSend}
                disabled={!userMessage.trim()}
                className="p-2.5 bg-gradient-to-br from-amber-600 to-amber-700 hover:from-amber-500 hover:to-amber-600 disabled:from-gray-700 disabled:to-gray-700 rounded-lg transition-all disabled:cursor-not-allowed shadow-lg"
              >
                <Send className="w-4 h-4 text-white" />
              </button>
            </div>

            <div className="flex gap-2">
              <button
                onClick={() => setViewMode('carousel')}
                className={`px-5 py-2.5 rounded-lg font-medium text-sm transition-all ${
                  viewMode === 'carousel' 
                    ? 'bg-gradient-to-r from-amber-600 to-amber-700 text-white shadow-lg shadow-amber-600/30' 
                    : 'bg-gray-800 text-gray-300 hover:bg-gray-700 border border-gray-700'
                }`}
              >
                Carousel
              </button>
              <button
                onClick={() => setViewMode('grid')}
                className={`px-5 py-2.5 rounded-lg font-medium text-sm transition-all ${
                  viewMode === 'grid' 
                    ? 'bg-gradient-to-r from-amber-600 to-amber-700 text-white shadow-lg shadow-amber-600/30' 
                    : 'bg-gray-800 text-gray-300 hover:bg-gray-700 border border-gray-700'
                }`}
              >
                Grid
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
};

export default LLMComparisonTool;